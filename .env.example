# ---------------------------------------------------------------------------
# Prestige Cars Chauffeur — Environment Variables
# Copy this file to .env and fill in the values before running the server.
# Never commit your actual .env file — it is listed in .gitignore.
# ---------------------------------------------------------------------------

# Server
APP_URL="http://localhost:3000"
APP_PORT=3000

# Auth
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="your_generated_secret_here"

# Stripe (optional — payments are simulated in dev mode)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Gemini AI (optional — used for AI concierge feature if enabled)
# GEMINI_API_KEY="your_gemini_api_key_here"
